
#include <iostream>
#include <string>
#include <vector>
#include <map>
using namespace std;

#define NO_OF_CHARS 256

void buildShiftTable(const string& pattern, int shift[]) {
    int m = pattern.length();

    for (int i = 0; i < NO_OF_CHARS; i++)
        shift[i] = m;

    for (int i = 0; i < m - 1; i++)
        shift[(unsigned char)pattern[i]] = m - 1 - i;
}

void horspoolSearch(const string& text, const string& pattern) {
    int n = text.length();
    int m = pattern.length();

    if (m > n) {
        cout << "Pattern longer than text. No match possible.\n";
        return;
    }

    int shift[NO_OF_CHARS];
    buildShiftTable(pattern, shift);

    bool found = false;
    int i = m - 1;  // align at last char of pattern

    cout << "\nSearching for pattern: \"" << pattern << "\" in the text\n";

    while (i < n) {
        int k = 0;

        // Match pattern right to left
        while (k < m && pattern[m - 1 - k] == text[i - k])
            k++;

        if (k == m) {
            cout << "Pattern found at index: " << (i - m + 1) << "\n";
            found = true;
        }

        // Shift by bad character table value
        i += shift[(unsigned char)text[i]];
    }

    if (!found)
        cout << "Pattern not found in text.\n";
}

void printShiftTable(const string& pattern) {
    int shift[NO_OF_CHARS];
    buildShiftTable(pattern, shift);
    int m = pattern.length();

    cout << "\n--- Shift Table (non-default entries) ---\n";
    cout << "Default shift (all others) = " << m << "\n";
    for (int i = 32; i < 127; i++) {
        if (shift[i] != m)
            cout << "  '" << (char)i << "' -> shift " << shift[i] << "\n";
    }
    cout << "-----------------------------------------\n";
}

int main() {

    string text1;
    cout << "Enter the TEXT : ";
    cin >> text1;
    string pattern1;
    cout << "Enter the Pattern: ";
    cin >> pattern1;
    printShiftTable(pattern1);
    horspoolSearch(text1, pattern1);

    return 0;
}
