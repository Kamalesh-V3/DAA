#include<iostream>
using namespace std;
int Calculation(string str,string sub){
    int n=str.length();
    int m=sub.length();
    int comp=0;
    int ali=0;
    for(int i=0;i<n;i++){
        cout<<str[i]<<" ";
    }
    cout<<"\n";
    for(int i=0;i<n-m+1;i++){
        int j=0;
        while(j<m && str[j+i]==sub[j]){
            comp=comp+1;
            j=j+1;
        }
        comp=comp+1;
        ali=ali+1;
        for(int k=0;k<i;k++){
                cout<<"  ";
            }
        for(int l=0;l<m;l++){
            cout<<sub[l]<<" ";
        }
        cout<<"\n";
        if(j==m){
            comp=comp-1;
            cout<<"Alignments: "<<ali<<endl;
            cout<<"Comparison: "<<comp<<endl;
            return i;
        }
    }
    cout<<"Alignments: "<<ali<<endl;
    cout<<"Comparison: "<<comp<<endl;
    return -1;
}
int main(){
    string str;
    cout<<"\nEnter the string:";
    getline(cin,str);
    string sub;
    cout<<"\nEnter substring to search:";
    getline(cin,sub);
    int s=Calculation(str,sub);
    if(s==-1){
        cout<<"Not found\n";
    }
    else{
        cout<<"Found at index: "<<s<<"\n";
    }
}
